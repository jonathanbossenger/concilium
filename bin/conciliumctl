#!/usr/bin/env node

const fs = require('fs');
const os = require('os');
const path = require('path');
const yaml = require('js-yaml');
const readline = require('readline/promises');
const { spawn, spawnSync } = require('child_process');

const SCRIPT = fs.realpathSync(process.argv[1]);
const BIN_DIR = path.dirname(SCRIPT);
const PROJECT_ROOT = path.resolve(BIN_DIR, '..');
const NODE_BIN = process.execPath;

const STATE_DIR = path.join(os.homedir(), '.concilium');
const PID_FILE = path.join(STATE_DIR, 'run.pid');
const LOG_FILE = path.join(STATE_DIR, 'server.log');
const CONFIG_FILE = path.join(STATE_DIR, 'config.yaml');

const PLATFORM = process.platform;
const SERVICE_LABEL = 'com.user.concilium';
const PLIST_PATH = path.join(os.homedir(), 'Library', 'LaunchAgents', `${SERVICE_LABEL}.plist`);
const SYSTEMD_DIR = path.join(os.homedir(), '.config', 'systemd', 'user');
const SYSTEMD_UNIT = path.join(SYSTEMD_DIR, 'concilium.service');

fs.mkdirSync(STATE_DIR, { recursive: true });

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function readPort() {
  if (!fs.existsSync(CONFIG_FILE)) return 7878;
  try {
    const yaml = fs.readFileSync(CONFIG_FILE, 'utf8');
    const match = yaml.match(/^\s*port:\s*["']?(\d+)["']?\s*$/m);
    if (!match) return 7878;
    const port = Number.parseInt(match[1], 10);
    return Number.isFinite(port) && port > 0 ? port : 7878;
  } catch {
    return 7878;
  }
}

const PORT = readPort();

async function fetchHealth() {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 1000);
  try {
    const response = await fetch(`http://127.0.0.1:${PORT}/api/health`, {
      signal: controller.signal,
    });
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    return response.json();
  } finally {
    clearTimeout(timeout);
  }
}

async function isResponding() {
  try {
    await fetchHealth();
    return true;
  } catch {
    return false;
  }
}

function printUrl() {
  const url = `http://127.0.0.1:${PORT}`;
  if (process.stdout.isTTY) {
    process.stdout.write(`  open:   \u001b]8;;${url}\u001b\\${url}\u001b]8;;\u001b\\\n`);
    return;
  }
  console.log(`  open:   ${url}`);
}

function readPid() {
  try {
    const pid = Number.parseInt(fs.readFileSync(PID_FILE, 'utf8').trim(), 10);
    return Number.isFinite(pid) && pid > 0 ? pid : null;
  } catch {
    return null;
  }
}

function canSignal(pid) {
  try {
    process.kill(pid, 0);
    return true;
  } catch {
    return false;
  }
}

function isServiceInstalled() {
  if (PLATFORM === 'darwin') return fs.existsSync(PLIST_PATH);
  if (PLATFORM === 'linux') return fs.existsSync(SYSTEMD_UNIT);
  return false;
}

function isStandaloneRunning() {
  const pid = readPid();
  return pid !== null && canSignal(pid);
}

function applyTemplate(templatePath, replacements) {
  let content = fs.readFileSync(templatePath, 'utf8');
  for (const [key, value] of Object.entries(replacements)) {
    content = content.split(key).join(value);
  }
  return content;
}

function run(file, args, options = {}) {
  const result = spawnSync(file, args, {
    stdio: options.stdio || 'inherit',
    cwd: options.cwd || PROJECT_ROOT,
    env: options.env || process.env,
    windowsHide: true,
  });
  if (result.error) {
    if (options.ignoreError) return false;
    throw result.error;
  }
  if (result.status !== 0) {
    if (options.ignoreError) return false;
    process.exit(result.status || 1);
  }
  return true;
}

async function promptFirstStartHostMode() {
  if (fs.existsSync(CONFIG_FILE)) return;
  if (!process.stdin.isTTY || !process.stdout.isTTY) return;

  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  });

  let answer = '';
  try {
    answer = (await rl.question('First start: run in local loopback mode only? [Y/n] ')).trim().toLowerCase();
  } finally {
    rl.close();
  }

  const host = answer === 'n' || answer === 'no' ? '0.0.0.0' : '127.0.0.1';
  const defaultConfig = {
    host,
    port: 7878,
    trustProxy: false,
    forceSecureCookies: false,
    publicServer: false,
    setupTokenHash: '',
    adminUser: '',
    adminPasswordHash: '',
    adminPasswordSalt: '',
    authSecret: '',
    githubToken: '',
    agents: [],
    onboardingCompleted: false,
  };

  fs.writeFileSync(CONFIG_FILE, yaml.dump(defaultConfig, { sortKeys: false }));
  console.log(`configured host: ${host}`);
}

async function startStandalone() {
  if (isStandaloneRunning()) {
    console.log(`already running (pid ${readPid()})`);
    return;
  }

  const logFd = fs.openSync(LOG_FILE, 'a');
  const child = spawn(NODE_BIN, [path.join(PROJECT_ROOT, 'server', 'index.js')], {
    cwd: PROJECT_ROOT,
    detached: true,
    stdio: ['ignore', logFd, logFd],
    env: process.env,
    windowsHide: true,
  });
  fs.closeSync(logFd);
  child.unref();
  fs.writeFileSync(PID_FILE, `${child.pid}\n`);

  for (let i = 0; i < 10; i += 1) {
    if (await isResponding()) {
      console.log(`started (pid ${child.pid}, port ${PORT}, mode standalone)`);
      printUrl();
      await printSetupTokenFromLog();
      return;
    }
    await sleep(200);
  }

  if (isStandaloneRunning()) {
    console.log(`started (pid ${child.pid}, port ${PORT}, mode standalone — not yet responding; tail ${LOG_FILE})`);
    printUrl();
    await printSetupTokenFromLog();
    return;
  }

  try { fs.unlinkSync(PID_FILE); } catch {}
  console.error(`error: failed to start; tail ${LOG_FILE}`);
  process.exit(1);
}

async function stopStandalone() {
  const pid = readPid();
  if (pid === null || !canSignal(pid)) {
    try { fs.unlinkSync(PID_FILE); } catch {}
    console.log('not running');
    return;
  }

  try { process.kill(pid); } catch {}
  for (let i = 0; i < 10; i += 1) {
    if (!canSignal(pid)) break;
    await sleep(300);
  }
  if (canSignal(pid)) {
    try { process.kill(pid, 'SIGKILL'); } catch {}
  }
  try { fs.unlinkSync(PID_FILE); } catch {}
  console.log(`stopped (was pid ${pid})`);
}

async function startService() {
  if (PLATFORM === 'darwin') {
    if (!run('launchctl', ['load', '-w', PLIST_PATH], { stdio: 'ignore', ignoreError: true })) {
      run('launchctl', ['start', SERVICE_LABEL]);
    }
  } else if (PLATFORM === 'linux') {
    run('systemctl', ['--user', 'start', 'concilium']);
  }

  for (let i = 0; i < 10; i += 1) {
    if (await isResponding()) {
      console.log(`started (mode service, port ${PORT})`);
      printUrl();
      await printSetupTokenFromLog();
      return;
    }
    await sleep(300);
  }
  console.log(`service started but not responding yet; tail ${LOG_FILE}`);
  printUrl();
  await printSetupTokenFromLog();
}

function stopService() {
  if (PLATFORM === 'darwin') {
    run('launchctl', ['unload', PLIST_PATH], { stdio: 'ignore', ignoreError: true });
  } else if (PLATFORM === 'linux') {
    run('systemctl', ['--user', 'stop', 'concilium'], { stdio: 'ignore', ignoreError: true });
  }
  console.log('stopped (service)');
}

function tailText(content, lines) {
  if (!content) return '';
  const parts = content.split(/\r?\n/);
  const slice = parts.slice(-lines);
  const text = slice.join('\n');
  return text && !text.endsWith('\n') ? `${text}\n` : text;
}

function parseLatestSetupToken(logContent) {
  if (!logContent) return null;
  const pattern = /\[concilium\]\s+Public-server setup token:\s+([^\s]+)\s+\(fingerprint\s+([0-9a-f]+)\)/g;
  let match = null;
  let latest = null;
  while ((match = pattern.exec(logContent)) !== null) {
    latest = { token: match[1], fingerprint: match[2] };
  }
  return latest;
}

async function printSetupTokenFromLog() {
  for (let i = 0; i < 10; i += 1) {
    try {
      const logContent = fs.readFileSync(LOG_FILE, 'utf8');
      const setupToken = parseLatestSetupToken(logContent);
      if (setupToken) {
        console.log(`  setup token: ${setupToken.token} (fingerprint ${setupToken.fingerprint})`);
        return true;
      }
    } catch {
      // ignore transient log-read failures during startup
    }
    await sleep(100);
  }
  return false;
}

function createMissingLogWatcher(stop) {
  let missingCount = 0;
  return {
    markMissing() {
      missingCount += 1;
      if (missingCount < 5) return false;
      console.error(`log file missing; stopping follow: ${LOG_FILE}`);
      stop(0);
      return true;
    },
    reset() {
      missingCount = 0;
    },
  };
}

async function cmdStart() {
  await promptFirstStartHostMode();
  if (await isResponding()) {
    console.log(`already running (port ${PORT})`);
    return;
  }
  if (isServiceInstalled()) {
    await startService();
  } else {
    await startStandalone();
  }
}

async function cmdStop() {
  if (isServiceInstalled()) {
    stopService();
  } else {
    await stopStandalone();
  }
}

async function cmdRestart() {
  await cmdStop();
  await sleep(400);
  await cmdStart();
}

async function cmdStatus() {
  if (await isResponding()) {
    const body = JSON.stringify(await fetchHealth());
    let mode = 'external (not managed by conciliumctl)';
    if (isServiceInstalled()) mode = 'service';
    else if (isStandaloneRunning()) mode = 'standalone';
    console.log('running');
    console.log(`  port:   ${PORT}`);
    console.log(`  mode:   ${mode}`);
    console.log(`  health: ${body}`);
    printUrl();
    return;
  }

  if (isStandaloneRunning()) {
    console.log(`stale: pid file present (pid ${readPid()}) but not responding`);
    return;
  }

  try { fs.unlinkSync(PID_FILE); } catch {}
  console.log('stopped');
  if (isServiceInstalled()) {
    console.log('  service installed but not running');
  }
}

async function cmdLogs() {
  fs.closeSync(fs.openSync(LOG_FILE, 'a'));
  const initial = fs.readFileSync(LOG_FILE, 'utf8');
  process.stdout.write(tailText(initial, 200));

  let position = Buffer.byteLength(initial);
  let interval = null;
  const onMissingLog = createMissingLogWatcher(stop);
  function stop(code = 0) {
    if (interval) clearInterval(interval);
    process.exit(code);
  }

  interval = setInterval(() => {
    let size;
    try {
      size = fs.statSync(LOG_FILE).size;
    } catch (err) {
      if (err && err.code === 'ENOENT') {
        position = 0;
        onMissingLog.markMissing();
        return;
      }
      console.error(`failed to read log file: ${err.message}`);
      stop(1);
      return;
    }
    onMissingLog.reset();
    if (size < position) position = 0;
    if (size === position) return;
    const stream = fs.createReadStream(LOG_FILE, { start: position, end: size - 1, encoding: 'utf8' });
    position = size;
    stream.pipe(process.stdout, { end: false });
  }, 500);

  process.on('SIGINT', stop);
  process.on('SIGTERM', stop);
  await new Promise(() => {});
}

async function cmdInstall() {
  if (isStandaloneRunning()) {
    console.log('stopping standalone instance first…');
    await stopStandalone();
  }

  const userPath = process.env.PATH || '';

  if (PLATFORM === 'darwin') {
    fs.mkdirSync(path.dirname(PLIST_PATH), { recursive: true });
    const plist = applyTemplate(path.join(PROJECT_ROOT, 'install', 'com.user.concilium.plist.tmpl'), {
      '@LABEL@': SERVICE_LABEL,
      '@NODE_BIN@': NODE_BIN,
      '@PROJECT_ROOT@': PROJECT_ROOT,
      '@LOG_FILE@': LOG_FILE,
      '@USER_PATH@': userPath,
    });
    fs.writeFileSync(PLIST_PATH, plist);
    run('launchctl', ['unload', PLIST_PATH], { stdio: 'ignore', ignoreError: true });
    run('launchctl', ['load', '-w', PLIST_PATH]);
    console.log('installed launchd agent');
    console.log(`  plist: ${PLIST_PATH}`);
    console.log(`  log:   ${LOG_FILE}`);
    console.log('service starts on login. To start now: conciliumctl start');
    return;
  }

  if (PLATFORM === 'linux') {
    fs.mkdirSync(SYSTEMD_DIR, { recursive: true });
    const unit = applyTemplate(path.join(PROJECT_ROOT, 'install', 'concilium.service.tmpl'), {
      '@NODE_BIN@': NODE_BIN,
      '@PROJECT_ROOT@': PROJECT_ROOT,
      '@LOG_FILE@': LOG_FILE,
      '@USER_PATH@': userPath,
    });
    fs.writeFileSync(SYSTEMD_UNIT, unit);
    run('systemctl', ['--user', 'daemon-reload']);
    run('systemctl', ['--user', 'enable', '--now', 'concilium']);
    console.log('installed systemd --user unit');
    console.log(`  unit: ${SYSTEMD_UNIT}`);
    console.log(`  log:  ${LOG_FILE}`);
    return;
  }

  console.error(`install is not supported on ${os.platform()} yet; use "conciliumctl start" for standalone mode`);
  process.exit(1);
}

function cmdUninstall() {
  if (PLATFORM === 'darwin') {
    if (!fs.existsSync(PLIST_PATH)) {
      console.log('not installed');
      return;
    }
    run('launchctl', ['unload', PLIST_PATH], { stdio: 'ignore', ignoreError: true });
    fs.unlinkSync(PLIST_PATH);
    console.log(`uninstalled (removed ${PLIST_PATH})`);
    return;
  }

  if (PLATFORM === 'linux') {
    if (!fs.existsSync(SYSTEMD_UNIT)) {
      console.log('not installed');
      return;
    }
    run('systemctl', ['--user', 'disable', '--now', 'concilium'], { stdio: 'ignore', ignoreError: true });
    fs.unlinkSync(SYSTEMD_UNIT);
    run('systemctl', ['--user', 'daemon-reload']);
    console.log(`uninstalled (removed ${SYSTEMD_UNIT})`);
    return;
  }

  console.log('not installed');
}

function usage() {
  console.log(`conciliumctl — concilium service control

Usage:
  conciliumctl start        start (service if installed, standalone otherwise)
  conciliumctl stop         stop
  conciliumctl restart      restart
  conciliumctl status       show running status and port
  conciliumctl logs         tail ${LOG_FILE}
  conciliumctl install      install as a user service (launchd / systemd --user)
  conciliumctl uninstall    remove the user service

Project: ${PROJECT_ROOT}
State:   ${STATE_DIR}`);
}

async function main() {
  const command = process.argv[2] || '';
  switch (command) {
    case 'start':
      await cmdStart();
      break;
    case 'stop':
      await cmdStop();
      break;
    case 'restart':
      await cmdRestart();
      break;
    case 'status':
      await cmdStatus();
      break;
    case 'logs':
      await cmdLogs();
      break;
    case 'install':
      await cmdInstall();
      break;
    case 'uninstall':
      cmdUninstall();
      break;
    case '-h':
    case '--help':
    case 'help':
    case '':
      usage();
      break;
    default:
      console.error(`unknown command: ${command}`);
      usage();
      process.exit(2);
  }
}

main().catch((err) => {
  console.error(err && err.message ? err.message : String(err));
  process.exit(1);
});
